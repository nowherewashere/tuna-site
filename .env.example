# ── Remnawave panel (VPN backend — source of truth for users/subscriptions) ──
REMNAWAVE_API_URL=https://panel.example.com
REMNAWAVE_API_TOKEN=
# Local dev only: the bare panel rejects plain HTTP (ProxyCheck). Set true so the
# client sends the X-Forwarded-Proto header a reverse proxy would add. Keep false in prod.
REMNAWAVE_LOCAL_PROXY_HEADERS=false
# Comma-separated internal-squad uuid(s) to assign new users to (so subscriptions have inbounds)
REMNAWAVE_TRIAL_SQUAD_UUIDS=

# ── Our database (linking + sessions + referral ledger) ──────────────────────
DATABASE_URL=postgres://tuna:tuna_local_dev@localhost:6790/tuna_site

# ── Sessions ─────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-string-min-16-chars
PUBLIC_DOMAIN=http://localhost:4300

# ── Trial / device policy ────────────────────────────────────────────────────
TRIAL_HOURS=24
TRIAL_HOURS_REFERRED=72
TRIAL_DEVICE_LIMIT=1
PAID_DEVICE_LIMIT=3

# ── Referral ─────────────────────────────────────────────────────────────────
REFERRAL_PERCENT=50
REFERRAL_PAYOUT_MIN_RUB=1000

# ── Optional integrations (not required for the core access flow) ────────────
EMAIL_PROVIDER_KEY=
EMAIL_FROM=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
CHATWOOT_BASE_URL=
CHATWOOT_WEBSITE_TOKEN=
CHATWOOT_HMAC_SECRET=
