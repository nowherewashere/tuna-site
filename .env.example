# The site is a pure client of the bot's public API (/api/v1/public/*). It has
# NO database, no Remnawave calls, no server secrets — all of that lives in the
# Python backend. See specs/tuna-vpn-website-backend-spec-en.md.

# Where to proxy /api/v1/* during local dev (`next dev`), so the browser talks
# to the API same-origin and the auth cookies are first-party.
# In production nginx serves this SPA and proxies /api/v1 to the app on the same
# domain, so this variable is only needed for local development.
NEXT_PUBLIC_API_ORIGIN=https://tunashop.tuna-transfer.xyz
